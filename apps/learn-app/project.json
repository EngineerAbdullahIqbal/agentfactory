{
  "name": "learn-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/learn-app",
  "targets": {
    "validate-flashcards": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx scripts/validate-flashcards.ts",
        "cwd": "apps/learn-app"
      }
    },
    "generate-anki": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/generate-anki-decks.js",
        "cwd": "apps/learn-app"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["validate-flashcards", "generate-anki"],
      "options": {
        "cwd": "apps/learn-app",
        "command": "pnpm build"
      },
      "outputs": ["{projectRoot}/build"],
      "cache": true,
      "inputs": ["docusaurusInputs", "^production"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/learn-app",
        "command": "pnpm start"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/learn-app",
        "command": "pnpm typecheck"
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "dependsOn": ["validate-flashcards"],
      "options": {
        "cwd": "apps/learn-app",
        "command": "pnpm typecheck"
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/learn-app"
      }
    }
  },
  "implicitDependencies": [
    "remark-interactive-python",
    "remark-content-enhancements",
    "remark-flashcards",
    "plugin-og-image",
    "plugin-structured-data",
    "summaries-plugin"
  ]
}
